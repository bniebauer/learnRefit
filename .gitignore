## .gitignore for a multi-project .NET solution
## Covers: Class Libraries, Console Apps, Unit Test Projects

# ===========================
# Build outputs
# ===========================
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/

# ===========================
# .NET / MSBuild
# ===========================
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs
project.lock.json
project.fragment.lock.json
artifacts/

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/
!**/packages/build/
nuget.config.bak
*.lock.json

# ===========================
# Visual Studio
# ===========================
.vs/
*.rsuser
*.vsp
*.vspx
*.sap

# Rider
.idea/
*.DotSettings.user

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ===========================
# Test results & coverage
# ===========================
TestResults/
[Tt]est[Rr]esult*/
*.trx
*.coverage
*.coveragexml
coverage*/
coverage.json
coverage.opencover.xml
coverage.cobertura.xml

# BenchmarkDotNet
BenchmarkDotNet.Artifacts/

# ===========================
# Publish / deployment
# ===========================
publish/
[Pp]ublish/
PublishProfiles/

# ===========================
# Runtime / temp files
# ===========================
*.tmp
*.temp
*.bak
*.swp
*~
*.pidb
*.svclog
*.scc

# ===========================
# OS generated
# ===========================

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~

# ===========================
# Secrets & environment
# ===========================
*.pfx
*.p12
*.cer
*.key
*.pem
appsettings.local.json
appsettings.*.local.json
.env
.env.*
secrets.json
launchSettings.json

# ===========================
# Entity Framework
# ===========================
# Uncomment if you don't want to track migrations
# Migrations/
